NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_SUPABASE_GOOGLE_OAUTH_ENABLED=false

# Use the same Supabase project URL as the public URL when running server-side admin operations.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_STORAGE_BUCKET=assets

ADMIN_EMAIL=admin@driftsai.com
# Or use a comma-separated allowlist:
# ADMIN_ALLOWED_EMAILS=owner@yourcompany.com,admin@yourcompany.com
# Optional Supabase user IDs that should receive admin access after login:
# ADMIN_ALLOWED_USER_IDS=your-supabase-user-id
# Quote passwords or secrets that contain #, spaces, or special shell characters.
ADMIN_PASSWORD="ChangeThisToAStrongPassword"
# Optional alternative to ADMIN_PASSWORD:
# ADMIN_PASSWORD_HASH="$2a$12$generated_bcrypt_hash_here"
ADMIN_SESSION_SECRET="replace_with_a_random_32+_character_secret"
AUTH_SESSION_SECRET="replace_with_a_random_32+_character_secret"
SITE_URL=https://driftsai.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS="your_app_password_here"
MAIL_FROM=you@gmail.com
NOTIFY_EMAIL=you@gmail.com

# Chatbot AI key is entered inside the admin CRM settings.
